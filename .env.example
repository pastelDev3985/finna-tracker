# ─── Database (Neon + Prisma) ───────────────────────────────────────────────
# Pooled connection string (serverless-friendly). Use Neon’s “Pooled” URI in Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
# Optional: direct/unpooled URL for `prisma migrate dev` from your machine (Neon “Direct”).
# DIRECT_URL="postgresql://..."

# ─── Auth.js / NextAuth v5 ───────────────────────────────────────────────────
# Generate: `openssl rand -base64 32`
AUTH_SECRET=
# Production app URL (must match your Vercel domain, no trailing slash)
AUTH_URL=http://localhost:3000
# If you still set these, keep AUTH_* in sync on Vercel:
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# ─── Email (Brevo / Sendinblue) ─────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Finora

# ─── Exchange rates (ExchangeRate-API; cached in PostgreSQL) ───────────────
EXCHANGE_RATE_API_KEY=
# Protect /api/cron/update-rates in production: Authorization: Bearer <secret>
CRON_SECRET=

# ─── AI insights (Gemini) — server-side only ────────────────────────────────
GEMINI_API_KEY=
